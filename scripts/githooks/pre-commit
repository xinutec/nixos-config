#!/usr/bin/env bash
# Single health gate. A commit must be healthy: this runs the full verify
# (scripts/verify.sh) — every machine's NixOS config is evaluated, plus ruff,
# mypy --strict, shellcheck, and the shared dev-lint rules.
# Slow by design; we optimise for healthy commits, not commit speed.
# Quiet on success: the full verify output is printed only when it FAILS, so a
# healthy commit isn't buried under eval noise (DL-GIT-PRECOMMIT-GATE).
# Bypass a genuine work-in-progress commit with:  git commit --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
if ! out=$(./scripts/verify.sh 2>&1); then
  printf '%s\n' "$out" >&2
  exit 1
fi
